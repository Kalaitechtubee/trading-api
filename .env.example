# ── Server Configuration ──────────────────────────────────────
PORT=5000
SCAN_INTERVAL_MS=30000

# ── API Keys ──────────────────────────────────────────────────
# Binance: Not required for public candle data, but recommended for high-frequency
BINANCE_API_KEY=
BINANCE_SECRET=

# Forex Data (e.g., FinancialModelingPrep or similar)
FOREX_API_KEY=your_forex_key_here

# ── Telegram Alerts ───────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT=your_chat_id_here

# ── Redis (Optional for Caching) ─────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Feature Toggles ───────────────────────────────────────────
DEBUG_SIGNALS=true
ENABLE_ML=true
ENABLE_BACKTEST=true
